    background: rgba(0,0,0,0.08);
    display: grid;
    place-items: center;
    cursor: pointer;
    z-index: 3;
  }

  .modal-close span {
    font-size: 20px;
    line-height: 1;
    color: #111;
  }

  /* ===== Menu content ===== */
  #nav-menu-container { padding: 26px 22px 22px; }

