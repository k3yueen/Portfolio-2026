    pointer-events: auto;
    text-decoration: none;
  }

  #nav-logo {
    height: 24px !important;
    width: auto !important;
    max-width: 180px;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    display: block;
  }

  .btn-square {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    border: 2px solid rgba(11, 11, 11, 0.9);
    background: #fff;
    color: #111;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 0 3px 0 rgba(11, 11, 11, 0.9);
    transition: transform 0.15s ease, background-color 0.2s ease, box-shadow 0.15s ease;
    pointer-events: auto;
  }

  .btn-square:hover { transform: translateY(-2px); }
  .btn-square:active { transform: translateY(1px); box-shadow: 0 1px 0 rgba(11,11,11,0.9); }

  @media (max-width: 600px) {
    #nav-container { padding: 14px; }
    .btn-square { width: 40px; height: 40px; border-radius: 10px; }
    #nav-logo { height: 24px !important; }
  }

  body.is-modal-open { overflow: hidden; }

  .modal-shell {
    position: fixed;
    inset: 0;
    z-index: 10000;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.18s ease;
  }

  .modal-shell.is-open {
