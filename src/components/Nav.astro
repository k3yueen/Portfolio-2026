</header>

<script is:inline>
  const body = document.body;

  const navOpenBtn = document.querySelector("[data-open-nav-modal]");
  const navCloseEls = document.querySelectorAll("[data-close-nav-modal]");
  const navShell = document.getElementById("nav-modal-container");
  const navPanel = document.getElementById("nav-modal");

  const contactOpenBtn = document.querySelector("[data-open-contact-modal]");
  const contactCloseEls = document.querySelectorAll("[data-close-contact-modal]");
  const contactShell = document.getElementById("contact-modal-container");
  const contactPanel = document.getElementById("contact-modal");

  const openContactFromMenu = document.querySelector("[data-open-contact-from-menu]");

  const lockScroll = (locked) => {
    body.classList.toggle("is-modal-open", locked);
  };

  const openShell = (shell, panel, triggerBtn) => {
    if (!shell || !panel) return;
    shell.classList.add("is-open");
    shell.setAttribute("aria-hidden", "false");
    lockScroll(true);

    if (triggerBtn) triggerBtn.setAttribute("aria-expanded", "true");
    setTimeout(() => panel.focus(), 0);
  };

  const closeShell = (shell, panel, triggerBtn) => {
    if (!shell || !panel) return;
    shell.classList.remove("is-open");
    shell.setAttribute("aria-hidden", "true");
    lockScroll(false);

    if (triggerBtn) triggerBtn.setAttribute("aria-expanded", "false");
    if (triggerBtn) triggerBtn.focus();
  };

  navOpenBtn?.addEventListener("click", () => openShell(navShell, navPanel, navOpenBtn));
  navCloseEls.forEach((el) => el.addEventListener("click", () => closeShell(navShell, navPanel, navOpenBtn)));

  contactOpenBtn?.addEventListener("click", () => openShell(contactShell, contactPanel, contactOpenBtn));
  contactCloseEls.forEach((el) => el.addEventListener("click", () => closeShell(contactShell, contactPanel, contactOpenBtn)));

  openContactFromMenu?.addEventListener("click", () => {
    closeShell(navShell, navPanel, navOpenBtn);
    setTimeout(() => openShell(contactShell, contactPanel, contactOpenBtn), 60);
  });

  window.addEventListener("keydown", (e) => {
    if (e.key !== "Escape") return;

    if (contactShell?.classList.contains("is-open")) {
      closeShell(contactShell, contactPanel, contactOpenBtn);
      return;
    }
    if (navShell?.classList.contains("is-open")) {
      closeShell(navShell, navPanel, navOpenBtn);
    }
  });

  document.querySelectorAll('a.nav-link[data-section]').forEach((a) => {
    a.addEventListener("click", (e) => {
      const id = a.getAttribute("data-section");
      if (!id) return;

      const el = document.getElementById(id);
      if (!el) return;

      e.preventDefault();
      closeShell(navShell, navPanel, navOpenBtn);
      setTimeout(() => el.scrollIntoView({ behavior: "smooth", block: "start" }), 50);
    });
  });
</script>

<style>
