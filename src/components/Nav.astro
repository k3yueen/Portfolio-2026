  }

  .modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.55);
    backdrop-filter: blur(2px);
  }

  .modal-panel {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: min(520px, calc(100% - 32px));
    max-height: min(84vh, 780px);
    background: #fff;
    border-radius: 18px;
    box-shadow: 0 18px 60px rgba(0,0,0,0.35);
    overflow: auto;
    outline: none;
  }

  .modal-panel-left { left: 16px; }
  .modal-panel-right { right: 16px; }

  @media (max-width: 720px) {
    .modal-panel {
      width: calc(100% - 24px);
      left: 12px !important;
      right: 12px !important;
